<div class="my-5">
    <h1 class="text-center mb-5">게시판</h1>
    <table id="tbl" class="table table-striped table-hover"></table>
    <div class="text-end">
        <button id="first" class="btn btn-primary btn-sm px-3">맨앞</button>
        <button id="prev" class="btn btn-primary btn-sm px-3">이전</button>
        <button id="span_page">1/10</button>
        <button id="next" class="btn btn-primary btn-sm px-3">다음</button>
        <button id="end" class="btn btn-primary btn-sm px-3">맨뒤</button>
    </div>
    <script id="temp" type="text/x-handlebars-template">
        <tbody>
            {{#each .}}
            <tr>
                <td>{{ID}}</td>
                <td>{{TITLE}}</td>
                <td>{{SNAME}}{{WRITER}}</td>
                <td class="text-end">{{FMT_DATE}}</td>
            </tr>
            {{/each}}
        </tbody> 
    </script>
</div>
<script>
    let page = 1;
    let size = 10;
    let last = 0;
    getList();
     $("#end").on("click",function(){
        page = last;
        getList();
    });
    $("#first").on("click",function(){
        page = 1;
        getList();
    });
    $("#next").on("click",function(){
        page++;
        getList();
    });
    $("#prev").on("click",function(){
        page--;
        getList();
    });
    function getList(){
        $.ajax({
            type:"get",
            url:"/posts/list.json",
            data: {page,size},
            success:function(data){
                const temp = Handlebars.compile($("#temp").html());
                $("#tbl").html(temp(data.list));
                last = Math.ceil(data.count/size);
               
                if(page == 1){
                    $("#prev").attr("disabled",true);
                    $("#first").attr("disabled",true);
                }
                else{
                    $("#prev").attr("disabled", false);
                    $("#first").attr("disabled", false);
                } 

               
                 $("#span_page").html(`${page}/${last}`);

                 if(page == last){
                    $("#next").attr("disabled",true)
                    $("#end").attr("disabled",true)
                 }
                 else{
                    $("#next").attr("disabled", false);
                    $("#end").attr("disabled", false);
                
                 }
            }
        });
    }
</script>